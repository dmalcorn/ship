{
  "name": "Ship",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  // Forward API and web dev server ports to the host
  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": { "label": "API Server", "onAutoForward": "notify" },
    "5173": { "label": "Web Dev Server", "onAutoForward": "openBrowser" },
    "*": { "onAutoForward": "silent" }
  },

  // Override host-derived paths so Windows host paths don't leak into the container
  "remoteEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },

  // Set up pnpm, install deps, migrate, and seed after container creation
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Fix Docker socket permissions on every container start (not just creation).
  // The socket is remounted from the host with root-only perms on each restart.
  // Retry loop handles the race where the socket isn't ready yet at container start.
  "postStartCommand": "bash -c 'for i in 1 2 3 4 5; do sudo chmod 666 /var/run/docker.sock 2>/dev/null && break || sleep 1; done'",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "ms-azuretools.vscode-docker",
        "antfu.unocss"
      ],
      "settings": {
        "typescript.preferences.importModuleSpecifier": "relative",
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Run as the non-root node user that the devcontainers image provides
  "remoteUser": "node"
}
