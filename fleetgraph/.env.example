# FleetGraph - Local Development Configuration
# Copy this to .env and customize values:
#   cp .env.example .env

# === Required ===

# Claude API key for LLM reasoning
ANTHROPIC_API_KEY=sk-ant-...

# Ship API base URL (local dev default)
SHIP_API_URL=http://localhost:3000

# Bearer token for Ship API authentication
# Generate via Ship UI or POST /api/api-tokens
FLEETGRAPH_API_TOKEN=ship_...

# === Tracing (required for graded artifacts) ===

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_CALLBACKS_BACKGROUND=true

# === Optional ===

# Express listen port (default: 3001)
PORT=3001

# Proactive scan interval (default: every 3 minutes)
# FLEETGRAPH_CRON_INTERVAL=*/3 * * * *
